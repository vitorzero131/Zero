{
  "name": "video-editor",
  "version": "1.0.0",
  "description": "AI-powered video caption generation system",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node --loader ts-node/esm server.ts",
    "captions": "node --loader ts-node/esm test-captions.ts",
    "build": "tsc",
    "dev": "nodemon --exec node --loader ts-node/esm server.ts"
  },
  "keywords": [
    "video",
    "captions",
    "ai",
    "claude",
    "ffmpeg"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
